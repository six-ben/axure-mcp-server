{
  "name": "axure-mcp-server",
  "version": "0.3.1",
  "description": "MCP server for extracting text and images from public Axure share links.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "axure-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "axure",
    "crawler",
    "cursor",
    "ai"
  ],
  "author": "55haitao",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "playwright": "^1.58.2",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
